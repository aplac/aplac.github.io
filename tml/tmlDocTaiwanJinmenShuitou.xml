<names>
<name script="Latin" ucd="LATIN">Shuitou Village</name><name script="Chinese-traditional" ucd="CJK">水頭</name></names>
<types>
<type script="Latin" ucd="LATIN">Shuitou</type><type script="Latin" ucd="LATIN">settlement</type></types>
<description>
<div script="Latin" ucd="LATIN">Shuitou is a village in Jinmen that is said to have been countinuously settled for more that 700 years. The village is famous for its large number of nicely decorated houses, built by rich merchants who had made a fortune trading in Southeast Asia.</div></description>
