<ent id="sBangkokSilomParsiCemetery"><admins><adminsys><admtop>sBangRak</admtop></adminsys></admins><types><type language="English" script="Latin" ucd="LATIN">cemetery</type><type language="English" script="Latin" ucd="LATIN">Parsi cemetery</type></types><names><name language="English" script="Latin" ucd="LATIN">Silom Parsi Cemetery</name><name language="English" script="Latin" ucd="LATIN">Bang Rak Parsi Cemetery</name></names><geography geotop="sBangRak" siteid="sBangRak"><street script="Latin" language="English">525 Soi Sueksa Witthaya</street><orientations><orientation system="geographic north">45</orientation></orientations><longitude crs="WGS84" deg="decimal" src="percol-down">100.5258015</longitude><latitude crs="WGS84" deg="decimal" src="percol-down">13.7242585</latitude></geography><events><event day="2018-02-04" lunar="2017-12-19" type="fieldwork"/></events><communities><community/></communities><description><div author="Oliver Streiter" language="English" script="Latin" ucd="LATIN">The Silom Parsi Cemetery is a Parsi cemetery in direct vicinity to the Hakka, Hokkien and Cantonese Cemeteries. To enter the cemetery one has to enter the alley to the Cantonese school and push a rolling gate open, which is unlocked during day time. A gardien is living insight the area of the Christian and Parsi Cemetery and he will lock and unlock the cemetery. Within the compound, the cemetery is separated by a fence in two parts, the Christian Cemetery and the Parsi Cemetery. Within the Parsi cemeteries there are a few older Parsi tombs, while newer tombs with Christian or Muslim symbolisms are included. In the center of the areal of the Parsi cemetery is a monument commenmorating the establishment of the cemetery. A simple wooden house on the compound of the Parsi cemetery is where the gardien of the cemeteris lives during day time.</div></description><culturaldomain/><pi/><ent id="sNewParsi29326"><names><name language="LGENG" script="Latin" ucd="LATIN">s29326</name><name la